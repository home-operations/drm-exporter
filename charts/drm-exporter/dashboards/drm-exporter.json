        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "drm_memory_used_bytes{node=~\"$node\", device=~\"$device\"} / drm_memory_total_bytes{node=~\"$node\", device=~\"$device\"}",
          "legendFormat": "{{node}} \u00b7 {{device}} \u00b7 {{pool}}",
          "range": true,
          "instant": false,
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
